**/.env.test.local
**/.env.production.local

# Turbo
.turbo

# vercel
.vercel

# Neon CLI (neonctl) — local org/project config artifact, regenerates per machine
.neon

# Independent app repos (own git + deploy rails) and their worktrees
apps/
.worktrees/

# Local Claude Code settings (never history)
.claude/settings.local.json

# Skill user-specific setup (e.g. a Telegram chat id) — see .claude/config/*.example.json for the template
.claude/config/*.json
!.claude/config/*.example.json

# Staging / reference asset drops (binaries; not repo history) — blanket-ignored so new drops
# (screenshots, PDFs, scratch notes) never sit as untracked/dirty. Files already committed here
# before 2026-07-16 stay tracked (gitignore doesn't retroactively untrack existing history).
gems/
references/

# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
**/.DS_Store
# Python bytecode (infra predicates)
__pycache__/
*.pyc

# references/despachobonsai — local-only reference clone (ML-sync impl). It has its own
# .git, node_modules, .next builds and .env secrets inside; git add silently no-ops on
# nested-repo files, so it stays untracked like design_handoff. To adopt the SOURCE into
# this repo: mv its .git to .git.local, then git add (junk dirs would need re-ignoring).
references/despachobonsai/
