{
  "extraKnownMarketplaces": {
    "dobby-foundation": {
      "source": {
        "source": "github",
        "repo": "danybgoode/dobby-foundation"
      }
    }
  },
  "enabledPlugins": {
    "ways-of-work@dobby-foundation": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/doc-format.mjs\" --hook"
          }
        ]
      }
    ]
  }
}
