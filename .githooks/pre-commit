#!/bin/sh
# Opt-in pre-commit guard for the generated status board. Enable once per clone with:
#   git config core.hooksPath .githooks
# Mirrors the CI check (.github/workflows/build-order-guard.yml) locally: if this commit
# touches the board's inputs (Roadmap/** or the scripts), it fails unless BUILD-ORDER.md
# is freshly generated. Fix: `node scripts/build-order.mjs` then re-stage it.
#
# CI is the real gate; this hook just catches drift before the (direct-to-main) commit lands.

changed=$(git diff --cached --name-only)
echo "$changed" | grep -qE '^(Roadmap/|scripts/build-order\.mjs|scripts/roadmap-to-notion\.mjs)' || exit 0

if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: node not found — skipping build-order check." >&2
  exit 0
fi

if ! node scripts/build-order.mjs --check; then
  echo "pre-commit: BUILD-ORDER.md is stale. Run 'node scripts/build-order.mjs' and stage it." >&2
  exit 1
fi
