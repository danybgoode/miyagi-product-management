#!/bin/sh
# Local-first pre-commit gate — BLOCKING. Auto-enabled via package.json's "prepare" script
# (git config core.hooksPath .githooks), so this runs for every clone with no manual step.
#
# Mirrors the fast, pure-node CI guards (all sub-second locally): build-order, doc-format,
# scripts/ + infra/ node:test suites. These used to be 5 separate GH Actions workflows firing
# on every push to main; consolidated into .github/workflows/guards.yml (PR-only, one job) —
# moved local-first because they were this repo's most-frequently-triggered workflows and each
# GH job bills a minimum 1 minute even for a 15-second check. guards.yml stays as the
# PR-triggered fallback safety net (see its own header).
#
# Path-gated: each check only runs if this commit touches its own inputs, so an unrelated
# commit pays zero cost. Bypass with `git commit --no-verify` if you genuinely need to — same
# escape hatch CI never really had anyway (this GitHub plan has no real branch-protection API).

changed=$(git diff --cached --name-only)

if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: node not found — skipping local guards (GH Actions PR check still applies)." >&2
  exit 0
fi

fail=0

if echo "$changed" | grep -qE '^(Roadmap/|scripts/build-order\.mjs|scripts/roadmap-to-notion\.mjs)'; then
  if ! node scripts/build-order.mjs --check >/dev/null 2>&1; then
    # Self-heal (build-order-ci-self-heal epic): the board is DERIVED — a stale copy is a
    # forgotten regen, not a judgment call. Regenerate and stage it into this same commit,
    # path-scoped to the one file the generator owns. Fail only if the regen itself errors.
    if node scripts/build-order.mjs && git add Roadmap/00-ideas/BUILD-ORDER.md; then
      echo "pre-commit: build-order — BUILD-ORDER.md was stale; regenerated and staged into this commit." >&2
    else
      echo "pre-commit: build-order self-heal failed — run 'node scripts/build-order.mjs' manually and inspect." >&2
      fail=1
    fi
  fi
fi

if echo "$changed" | grep -qE '^(Roadmap/|scripts/doc-format\.mjs)'; then
  if ! node scripts/doc-format.mjs --check; then
    echo "pre-commit: doc-format failed — see findings above. Fix or 'node scripts/doc-format.mjs --fix' where safe." >&2
    fail=1
  fi
fi

if echo "$changed" | grep -qE '^scripts/'; then
  if ! node --test 'scripts/lib/*.test.mjs' 'scripts/*.test.mjs'; then
    echo "pre-commit: scripts/ node:test failed — see output above." >&2
    fail=1
  fi
fi

if echo "$changed" | grep -qE '^infra/'; then
  if ! node --test 'infra/gcp/test/*.test.js' 'infra/gcp/test/*.test.mjs'; then
    echo "pre-commit: infra/ node:test failed — see output above." >&2
    fail=1
  fi
fi

if [ "$fail" -ne 0 ]; then
  echo "pre-commit: one or more checks failed. Fix and re-stage, or 'git commit --no-verify' to bypass." >&2
  exit 1
fi

exit 0
