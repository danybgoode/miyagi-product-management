#!/bin/sh
# Local-first pre-push — ADVISORY (never blocks the push, exits 0 regardless). Auto-enabled
# via package.json's "prepare" script (git config core.hooksPath .githooks).
#
# Runs a best-effort Roadmap → Notion sync for direct pushes from local `main`. It must never run
# from a feature branch: `--sync` is a full-board rebuild, and projecting one branch's worldview
# would clobber parallel work. The public root repo's path-gated push workflow is the reliable
# post-merge rail; local history makes this hook a faster, unmetered first attempt.
#
# Advisory by design: a slow/failed Notion sync should never block a push. Requires
# NOTION_TOKEN — either already in your shell env, or in a root .env.local (gitignored;
# NOTION_TOKEN=<value>, one line, matching the `gh secret list` token) — if neither is present,
# this silently no-ops and relies on the nightly cron.

load_dotenv_var() {
  # Minimal, safe parse of a single KEY=VALUE line — not a full shell-source of the file (dotenv
  # syntax isn't guaranteed to be valid shell, e.g. unescaped # in a value). A linked worktree
  # does not carry the primary checkout's untracked .env.local, so fall back to the directory that
  # owns the shared git common-dir. Prints the value.
  dotenv_file=".env.local"
  if [ ! -f "$dotenv_file" ]; then
    common_dir=$(git rev-parse --git-common-dir 2>/dev/null)
    primary_root=$(dirname "$common_dir")
    dotenv_file="$primary_root/.env.local"
  fi
  [ -f "$dotenv_file" ] || return 0
  val=$(grep -E "^$1=" "$dotenv_file" | head -1 | cut -d= -f2-)
  printf '%s' "$val" | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//"
}

changed_roadmap() {
  # Any commit between the pushed remote ref and local HEAD touching Roadmap/** or the script.
  git diff --name-only @{push}...HEAD 2>/dev/null | grep -qE '^(Roadmap/|scripts/roadmap-to-notion\.mjs)'
}

if ! command -v node >/dev/null 2>&1; then
  exit 0
fi

# Git provides the actual local/remote ref pairs on stdin. Gate on those, not HEAD: a developer can
# be checked out on main while explicitly pushing/deleting some other ref. Only a normal
# refs/heads/main → refs/heads/main push may project the working tree; every other shape relies on
# the reliable post-push workflow.
pushes_main=false
while read -r local_ref _local_sha remote_ref _remote_sha; do
  if [ "$local_ref" = "refs/heads/main" ] && [ "$remote_ref" = "refs/heads/main" ]; then
    pushes_main=true
  fi
done
if [ "$pushes_main" != "true" ]; then
  echo "pre-push: skipping full Notion projection for a non-main ref; main/push workflow owns it." >&2
  exit 0
fi

# @{push} can fail on a brand-new branch with no upstream yet — fall back to "did HEAD change
# Roadmap/** at all" via a cheap recent-commit check instead of blocking on git plumbing.
if ! changed_roadmap && ! git show --stat -1 HEAD 2>/dev/null | grep -qE '^\s*(Roadmap/|scripts/roadmap-to-notion\.mjs)'; then
  exit 0
fi

if [ -z "$NOTION_TOKEN" ]; then
  loaded=$(load_dotenv_var NOTION_TOKEN)
  [ -n "$loaded" ] && NOTION_TOKEN="$loaded"
fi

if [ -z "$NOTION_TOKEN" ]; then
  echo "pre-push: Roadmap/** changed but NOTION_TOKEN isn't set locally — skipping live sync." >&2
  echo "pre-push: the board will catch up via notion-sync.yml's nightly cron (up to ~24h)." >&2
  exit 0
fi

if [ -z "$NOTION_DB_ID" ]; then
  loaded=$(load_dotenv_var NOTION_DB_ID)
  NOTION_DB_ID="${loaded:-eb68a1fd05f443b184b6b5b3db89f47e}" # same default as notion-sync.yml — an id, not a secret
fi

export NOTION_TOKEN NOTION_DB_ID
# Detached background run — the sync is advisory and network-bound (10-60s against Notion's API),
# so it must never hold the push. Resolve the per-worktree git path instead of assuming `.git/`
# is a directory: in a linked worktree `.git` is a pointer file, and redirecting below it prevents
# the background process from starting at all. The public push workflow remains the safety net.
notion_log=$(git rev-parse --git-path notion-sync.last.log 2>/dev/null)
[ -n "$notion_log" ] || notion_log=".git/notion-sync.last.log"
echo "pre-push: syncing Roadmap → Notion in background (log: $notion_log)..." >&2
nohup node scripts/roadmap-to-notion.mjs --sync >"$notion_log" 2>&1 &

exit 0
